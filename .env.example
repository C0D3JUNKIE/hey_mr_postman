# ── Copy to .env and fill in. NEVER commit the real .env. ──────────────────
# Every key here is referenced by a `*_env` field in config/scenarios/example.yaml.

# Anthropic LLM access
ANTHROPIC_API_KEY=

# Hub aggregation mailbox (IMAP read) — see transport.imap.password_env
HUB_IMAP_PASSWORD=

# Per-brand sending identities (SMTP) — see sending_identities[*].password_env
BRAND_A_SUPPORT_PASSWORD=
BRAND_B_CONTACT_PASSWORD=

# Global kill switch — any truthy value forces draft_only regardless of config.
# (unset / empty / 0 / false = off)
KILL_SWITCH=